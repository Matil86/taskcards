<?xml version="1.0" encoding="utf-8"?><!--
   Data extraction rules for TaskCards app
   Applies to devices with API level >= 31 (Android 12 and above)
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Include DataStore preferences (settings) for cloud backup -->
        <include domain="file" path="datastore/"/>
    </cloud-backup>

    <device-transfer>
        <!-- Include all user data for device-to-device transfers -->
        <include domain="file" path="datastore/"/>
    </device-transfer>
</data-extraction-rules>