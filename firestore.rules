rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isListCreator(listId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/lists/$(listId)).data.creatorUid == request.auth.uid;
    }

    function isContributor(listId) {
      return isAuthenticated() &&
        request.auth.uid in get(/databases/$(database)/documents/lists/$(listId)).data.contributors;
    }

    function validateListData() {
      let data = request.resource.data;
      return data.keys().hasAll(['creatorUid', 'contributors', 'name', 'createdAt', 'lastModifiedAt'])
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 100
        && data.contributors is list
        && data.contributors.size() > 0
        && data.creatorUid is string;
    }

    function validateTaskData() {
      let data = request.resource.data;
      return (
        data.keys().hasAll(['text', 'order', 'done', 'removed', 'timestamp'])
        && data.text is string
        && data.order is int
        && data.done is bool
        && data.removed is bool
        && data.timestamp is int
        && data.text.size() > 0
        && data.text.size() <= 500
        && data.order >= -1000000
        && data.order <= 1000000
        && (!data.keys().hasAny(['dueDate']) || data.dueDate == null || data.dueDate is int)
        && (!data.keys().hasAny(['reminderType']) || data.reminderType is string)
      );
    }

    match /lists/{listId} {
      // Any authenticated user can read a list they are a contributor to,
      // or discover lists via whereArrayContains query
      allow read: if isAuthenticated();

      // Create: only if creator sets themselves as creatorUid and contributor
      allow create: if isAuthenticated()
        && validateListData()
        && request.resource.data.creatorUid == request.auth.uid
        && request.auth.uid in request.resource.data.contributors;

      // Update: contributors can update, OR any authenticated user can add
      // themselves to contributors (QR-code join) via arrayUnion
      allow update: if isContributor(listId)
        || (isAuthenticated()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['contributors'])
            && request.resource.data.contributors.hasAll(resource.data.contributors)
            && request.resource.data.contributors.removeAll(resource.data.contributors).size() == 1
            && request.resource.data.contributors.removeAll(resource.data.contributors)[0] == request.auth.uid);

      // Delete: only the creator
      allow delete: if isListCreator(listId);

      // Tasks subcollection
      match /tasks/{taskId} {
        allow read: if isAuthenticated();
        allow create, update: if isContributor(listId) && validateTaskData();
        allow delete: if isContributor(listId);
      }
    }

    // Deny all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
