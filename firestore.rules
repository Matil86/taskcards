rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the current user owns (created) this list.
    // List metadata is stored under /users/{uid}/lists/{listId} when created.
    // This covers both local lists and lists the user accepted via QR-share.
    function isListOwner(listId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)/lists/$(listId));
    }

    // Lists collection - top-level task storage (collaborative sharing model)
    //
    // Security model: TaskCards uses "access by link" sharing (similar to Google Docs
    // with a shared link). List IDs are cryptographically random Firestore-generated
    // IDs (20 chars, base62) and are not guessable. Sharing is intentional via QR code.
    //
    // Read/create/update: Any authenticated user who knows the list ID may read and
    // collaborate. This enables the QR-code sharing feature.
    //
    // Delete: Only the list owner may delete a list to prevent data loss by
    // non-owners. Ownership is tracked via /users/{uid}/lists/{listId}.
    match /lists/{listId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isListOwner(listId);

      // Tasks subcollection within a list
      match /tasks/{taskId} {
        allow read: if isAuthenticated();
        allow create, update: if isAuthenticated() && validateTaskData();
        allow delete: if isAuthenticated();
      }
    }

    // Validation function for task data
    function validateTaskData() {
      let data = request.resource.data;

      return (
        // Required fields
        data.keys().hasAll(['text', 'order', 'done', 'removed', 'timestamp']) &&

        // Type validation
        data.text is string &&
        data.order is int &&
        data.done is bool &&
        data.removed is bool &&
        data.timestamp is int &&

        // Business rule validation
        data.text.size() > 0 &&
        data.text.size() <= 500 &&
        data.order >= -1000000 &&
        data.order <= 1000000 &&

        // Optional fields validation
        (!data.keys().hasAny(['dueDate']) || data.dueDate == null || data.dueDate is int) &&
        (!data.keys().hasAny(['reminderType']) || data.reminderType is string)
      );
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
